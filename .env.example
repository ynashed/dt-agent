# Copy to .env and fill in. .env is gitignored.

# Primary LLM key — used for GPT-5.3-codex via the NV-internal proxy at
# https://inference-api.nvidia.com/v1. Get from https://build.nvidia.com
# (requires NV ID).
NV_API_KEY=

# VLM (Cosmos Reason 2 8B). Two ways to run it:
#
# A) Self-hosted via docker-compose (default for this repo — see the `vlm`
#    service in docker-compose.yml). The local endpoint is unauthenticated
#    so NV_VLM_API_KEY can be empty; just point the wrapper at it:
NV_VLM_BASE_URL=http://localhost:8000/v1
NV_VLM_API_KEY=
#
# B) NVIDIA-hosted on build.nvidia.com. Cosmos Reason 2 8B lives on the
#    integrate.api.nvidia.com NIM endpoint, which is a *different* auth
#    surface than the inference-api proxy above; NV_API_KEY does NOT
#    authenticate there. Generate this from the "Get API Key" panel at
#    https://build.nvidia.com/nvidia/cosmos-reason2-8b and unset
#    NV_VLM_BASE_URL so the default (integrate.api.nvidia.com/v1) applies.
#    NV_VLM_API_KEY=<your build.nvidia.com cosmos-reason2-8b key>

# NGC API key — needed to pull the NIM image from nvcr.io and to
# revalidate the model weights at runtime. Generate at
# https://ngc.nvidia.com/setup/api-key. Then run, one-time:
#   docker login nvcr.io -u '$oauthtoken' -p $NGC_API_KEY
NGC_API_KEY=
