# Copy to .env and fill in. .env is gitignored.

# Primary LLM key — used for GPT-5.3-codex via the NV-internal proxy at
# https://inference-api.nvidia.com/v1. Get from https://build.nvidia.com
# (requires NV ID).
NV_API_KEY=

# VLM (Cosmos Reason 2 8B). Two ways to run it:
#
# A) Self-hosted via docker-compose — the default. The `vlm` service in
#    docker-compose.yml runs the NIM at http://localhost:8000/v1 and the
#    wrapper hits that endpoint by default with no auth needed. Leave
#    both vars below unset for this path.
#
# B) NVIDIA-hosted on build.nvidia.com. Cosmos Reason 2 8B lives at
#    integrate.api.nvidia.com — a *different* auth surface than the
#    inference-api.nvidia.com proxy above; NV_API_KEY does NOT
#    authenticate there. To use the hosted variant, uncomment both lines
#    below and supply a key from
#    https://build.nvidia.com/nvidia/cosmos-reason2-8b -> Get API Key.
# NV_VLM_BASE_URL=https://integrate.api.nvidia.com/v1
# NV_VLM_API_KEY=<your build.nvidia.com cosmos-reason2-8b key>

# NGC API key — needed to pull the NIM image from nvcr.io and to
# revalidate the model weights at runtime. Generate at
# https://ngc.nvidia.com/setup/api-key. Then run, one-time:
#   docker login nvcr.io -u '$oauthtoken' -p $NGC_API_KEY
NGC_API_KEY=
