# Copy to .env and fill in. .env is gitignored.

# Primary LLM key — used for GPT-5.3-codex via the NV-internal proxy at
# https://inference-api.nvidia.com/v1. Get from https://build.nvidia.com
# (requires NV ID).
NV_API_KEY=

# VLM key — Cosmos Reason 2 8B is hosted on the build.nvidia.com NIM
# endpoint (https://integrate.api.nvidia.com/v1), which is a different auth
# surface than the inference-api proxy above; the same NV_API_KEY does NOT
# authenticate there. Generate this one from the "Get API Key" panel on
# https://build.nvidia.com/nvidia/cosmos-reason2-8b. Falls back to
# NV_API_KEY if unset.
NV_VLM_API_KEY=

# Override the VLM base URL if you need to point at a different proxy.
# Default (unset) -> https://integrate.api.nvidia.com/v1
# NV_VLM_BASE_URL=
