FROM nvcr.io/nvidia/isaac-sim:5.1.0

# Install MCP server deps into Isaac Sim's bundled Python.
# python.sh wraps the embedded interpreter with the right env vars.
RUN /isaac-sim/python.sh -m pip install --no-cache-dir \
        "fastmcp>=2.0" \
        "python-dotenv>=1.0"

WORKDIR /workspace/dt-agent
